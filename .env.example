# =============================================================================
# whisper-cli 多组 IM -> AI CLI 转发服务配置
# =============================================================================
# 每组 agent 是一个独立的转发桥梁：IM 平台 ↔ AI CLI
# 按 AGENT_<N>_* 格式编号，所有组可同时启动
#
# 配置项说明:
#   AGENT_<N>_NAME         = 组名（日志标识）
#   AGENT_<N>_PLATFORM     = IM 平台: feishu | wecom
#   AGENT_<N>_AI_CLI       = AI 命令行: codebuddy | cursor
#   AGENT_<N>_<PLATFORM>_* = 该平台的凭证 (APP_ID, APP_SECRET 等)
#   AGENT_<N>_<CLI>_*      = 该 AI CLI 的凭证 (API_KEY 等)
#   AGENT_<N>_ALLOWLIST    = 允许的用户 open_id，逗号分隔 (可选)
# =============================================================================

# -----------------------------------------------------------------------------
# Agent Group 1: Feishu ↔ CodeBuddy
# -----------------------------------------------------------------------------
AGENT_1_NAME=CodeBuddy Bot
AGENT_1_PLATFORM=feishu
AGENT_1_AI_CLI=codebuddy
AGENT_1_FEISHU_APP_ID=cli_xxxxxxxxxxxx
AGENT_1_FEISHU_APP_SECRET=xxxxxxxxxxxx
AGENT_1_FEISHU_ALLOWLIST=ou_xxxxxxxxxxxx
AGENT_1_CODEBUDDY_API_KEY=ck_xxxxxxxxxxxx
AGENT_1_CODEBUDDY_INTERNET_ENVIRONMENT=ioa

# -----------------------------------------------------------------------------
# Agent Group 2: Feishu ↔ Cursor
# -----------------------------------------------------------------------------
AGENT_2_NAME=Cursor Bot
AGENT_2_PLATFORM=feishu
AGENT_2_AI_CLI=cursor
AGENT_2_FEISHU_APP_ID=cli_yyyyyyyyyyyy
AGENT_2_FEISHU_APP_SECRET=yyyyyyyyyyyy
AGENT_2_CURSOR_API_KEY=crsr_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Agent Group 3: WeCom (企微) ↔ CodeBuddy (示例)
# -----------------------------------------------------------------------------
# AGENT_3_NAME=WeCom CodeBuddy
# AGENT_3_PLATFORM=wecom
# AGENT_3_AI_CLI=codebuddy
# AGENT_3_WECOM_CORP_ID=wwxxxxxxxxxxxx
# AGENT_3_WECOM_CORP_SECRET=xxxxxxxxxxxx
# AGENT_3_WECOM_TOKEN=xxxxxxxxxxxx
# AGENT_3_WECOM_ENCODING_AES_KEY=xxxxxxxxxxxx
# AGENT_3_CODEBUDDY_API_KEY=ck_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 全局配置（可选）
# -----------------------------------------------------------------------------
# 工作目录（AI CLI 执行时的 cwd），默认 = 项目根目录
# WORKDIR=/Users/r/code/dev/whisper-cli

# CodeBuddy 可执行文件路径，留空则自动探测常见位置
#   macOS ARM:  /opt/homebrew/bin/codebuddy
#   macOS x64:  /usr/local/bin/codebuddy
#   Linux:      /usr/local/bin/codebuddy, /home/linuxbrew/.linuxbrew/bin/codebuddy, ~/.local/bin/codebuddy
# CODEBUDDY_BIN=/opt/homebrew/bin/codebuddy

# Cursor Agent 可执行文件路径, 留空则自动探测常见位置
#   macOS/Linux: ~/.local/bin/agent, /opt/homebrew/bin/agent, /usr/local/bin/agent
# CURSOR_AGENT_BIN=~/.local/bin/agent

# 日志级别: debug | info | warn | error
# LOG_LEVEL=info
